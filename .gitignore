# Ignore everything
*

# Whitelist root level files
!.gitignore
!package.json
!package-lock.json
!tsconfig.json
!index.html
!README.md

# Whitelist directories
!public/
!scripts/
!server/
!src/

# Allow everything inside whitelisted directories
!public/**
!scripts/**
!server/**
!src/**

# Keep local data files out of git by default
data/
